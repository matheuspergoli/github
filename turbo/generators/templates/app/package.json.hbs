{
	"name": "@repo/{{ name }}",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"license": "MIT",
	"scripts": {
		"build": "bun build --target=bun --minify --sourcemap=external --packages=external --outdir=dist ./src/index.ts",
		"start": "bun ./dist/index.js",
		"dev": "bun --watch ./src/index.ts",
		"clean": "rm -rf .turbo .typescript dist node_modules",
		"typecheck": "tsc --noEmit --emitDeclarationOnly false"
	},
	"devDependencies": {
		"@repo/tsconfig": "workspace:*",
		"@types/bun": "^1.3.11",
		"typescript": "^5.9.3"
	}
}
